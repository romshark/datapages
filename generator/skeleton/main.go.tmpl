func main() {
	loadEnvFile(".env")

	host := envOr("HOST", "localhost")
	port := envOr("PORT", "8080")

	ctx, cancel := signal.NotifyContext(context.Background(), os.Interrupt)
	defer cancel()

	var opts []{{.Gen}}.ServerOption
	withAccessLogger(&opts)
{{- if .HasSession}}
	withAuth(&opts)
	withCSRFProtection(&opts)
{{- end}}
{{- if .Prometheus}}
	initMetrics(&opts)
{{- end}}

{{- if .HasSession}}

	messageBroker, sessionManager := connectNATS()
{{- else}}

	messageBroker := connectNATS()
{{- end}}

	// TODO: Initialize your app.
	a := &app.App{}

{{- if .HasSession}}
	s := {{.Gen}}.NewServer(a, messageBroker, sessionManager, opts...)
{{- else}}
	s := {{.Gen}}.NewServer(a, messageBroker, opts...)
{{- end}}
	listenAndServe(ctx, s, net.JoinHostPort(host, port))
}

func envOr(key, fallback string) string {
	if v := os.Getenv(key); v != "" {
		return v
	}
	return fallback
}

// loadEnvFile reads a .env file and sets variables in the process
// environment. Existing variables are not overwritten.
func loadEnvFile(path string) {
	f, err := os.Open(path)
	if err != nil {
		return
	}
	defer func() { _ = f.Close() }()
	s := bufio.NewScanner(f)
	for s.Scan() {
		line := strings.TrimSpace(s.Text())
		if line == "" || line[0] == '#' {
			continue
		}
		k, v, ok := strings.Cut(line, "=")
		if !ok {
			continue
		}
		if os.Getenv(k) == "" {
			_ = os.Setenv(k, v)
		}
	}
}

func withAccessLogger(opts *[]{{.Gen}}.ServerOption) {
	logger := slog.New(slog.NewJSONHandler(os.Stderr, &slog.HandlerOptions{
		Level: slog.LevelInfo,
	}))
	*opts = append(*opts, {{.Gen}}.WithMiddleware(func(next http.Handler) http.Handler {
		return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
			logger.Info("access",
				slog.String("method", r.Method),
				slog.String("path", r.URL.Path))
			next.ServeHTTP(w, r)
		})
	}))
}
{{- if .HasSession}}

func withAuth(opts *[]{{.Gen}}.ServerOption) {
	*opts = append(*opts, {{.Gen}}.WithAuth({{.Gen}}.AuthConfig{}))
}

func withCSRFProtection(opts *[]{{.Gen}}.ServerOption) {
	secret := os.Getenv("CSRF_SECRET")
	tm, err := csrfhmac.New([]byte(secret))
	if err != nil {
		slog.Error("initializing CSRF token manager", slog.Any("err", err))
		os.Exit(1)
	}
	*opts = append(*opts, {{.Gen}}.WithCSRFProtection({{.Gen}}.CSRFConfig{
		TokenManager:   tm,
		DevBypassToken: os.Getenv("CSRF_DEV_BYPASS"),
	}))
}
{{- end}}

{{- if .HasSession}}

func connectNATS() (
	*natsjs.MessageBroker,
	*natskv.SessionManager[app.Session],
) {
{{- else}}

func connectNATS() *natsjs.MessageBroker {
{{- end}}
	u := os.Getenv("NATS_URL")
	if u == "" {
		slog.Error("NATS_URL not set")
		os.Exit(2)
	}
{{- if .HasSession}}

	sessionEncryptionKeyHex := os.Getenv("SESSION_ENCRYPTION_KEY")
	if sessionEncryptionKeyHex == "" {
		slog.Error("SESSION_ENCRYPTION_KEY not set")
		os.Exit(2)
	}
	sessionEncryptionKey, err := hex.DecodeString(sessionEncryptionKeyHex)
	if err != nil {
		slog.Error("decoding SESSION_ENCRYPTION_KEY", slog.Any("err", err))
		os.Exit(1)
	}
{{- end}}

	conn, err := nats.Connect(u)
	if err != nil {
		slog.Error("opening NATS connection", slog.Any("err", err))
		os.Exit(1)
	}
{{- if .HasSession}}

	sessionManager, err := natskv.New[app.Session](
		conn,
		sesstokgen.Generator{Length: sesstokgen.DefaultLength},
		natskv.Config{EncryptionKey: sessionEncryptionKey},
	)
	if err != nil {
		slog.Error("initializing session manager", slog.Any("err", err))
		os.Exit(1)
	}
{{- end}}

	messageBroker, err := natsjs.New(conn, natsjs.Config{
		StreamConfig: &nats.StreamConfig{
			Name:    "DATAPAGES",
			Storage: nats.MemoryStorage,
		},
	})
	if err != nil {
		slog.Error("initializing message broker", slog.Any("err", err))
		os.Exit(1)
	}

{{- if .HasSession}}

	return messageBroker, sessionManager
{{- else}}

	return messageBroker
{{- end}}
}

{{- if .Prometheus}}

func initMetrics(opts *[]{{.Gen}}.ServerOption) {
	host := envOr("HOST_METRICS", "localhost")
	port := envOr("PORT_METRICS", "9090")
	*opts = append(*opts, {{.Gen}}.WithPrometheus({{.Gen}}.PrometheusConfig{
		Host: net.JoinHostPort(host, port),
	}))
}
{{- end}}

func listenAndServe(ctx context.Context, s *{{.Gen}}.Server, host string) {
	pathCert := os.Getenv("PATH_TLS_CERT")
	pathKey := os.Getenv("PATH_TLS_KEY")

	var err error
	if pathCert == "" && pathKey == "" {
		err = s.ListenAndServe(ctx, host)
	} else {
		err = s.ListenAndServeTLS(ctx, host, pathCert, pathKey)
	}
	if err != nil && !errors.Is(err, http.ErrServerClosed) {
		slog.Error("listening", slog.Any("err", err))
	}
}
