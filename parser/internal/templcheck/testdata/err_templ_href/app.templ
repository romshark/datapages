package app

import (
	"fmt"

	"datapagestest/fixture/err_templ_href/datapagesgen/href"
	"datapagestest/fixture/err_templ_href/urls"
)

templ page(dynamicValue string) {
	/* ErrHardcodedAction */
	<form action="/submit">
		<button type="submit">Submit</button>
	</form>
	<a href="https://example.com">OK external</a>
	<a href="#fragment">OK fragment</a>
	<a href="mailto:test@example.com">OK mailto</a>
	<a href="tel:+1234567890">OK tel</a>
	//datapages:nolint
	<a href="/suppressed">Suppressed</a>
	//datapages:nolint // This is okay because I said so.
	<a href="/suppressed">Suppressed with explanation</a>
	<a href={ ConstantStringOK }>Constant external</a>
	<a href={ "https://data-star.dev" }>Literal</a>
	<a href={ href.PageIndex() }>OK href package</a>
	<a href={ href.PageProfile() }>OK href package</a>
	<a href={ href.External("https://example.com") }>OK href.External</a>
	<a href={ href.External(fmt.Sprintf("mailto:%s", "test@example.com")) }>
		OK href.External dynamic
	</a>
	//
	// --- ERRORS ---
	//
	/* ErrHardcodedHref */
	<a href="/login">Login</a>
	/* ErrHardcodedHref */
	<a href="/profile">Profile</a>
	/* ErrHardcodedHref: static asset */
	<a href="/static/style.css">Static</a>
	/* ErrHardcodedHref: string literal in expression */
	<a href={ "/settings" }>Settings</a>
	/* ErrHardcodedHref: string concatenation */
	<a href={ "/set" + "tings" }>Settings</a>
	/* ErrHrefUnverifiable: string concatenation with variable */
	<a href={ "/set" + dynamicValue }>Settings</a>
	/* ErrHrefUnverifiable: function wrapping string literal */
	<a href={ templ.SafeURL("/about") }>About</a>
	/* ErrHrefUnverifiable: constant reference */
	<a href={ templ.SafeURL(ConstantStringNOTOK) }>Constant wrapped</a>
	/* ErrHrefUnverifiable: function wrapping string literal */
	<a href={ templ.SafeURL("https://data-star.dev") }>Datastar</a>
	<a href={ ConstantStringNOTOK }>Constant plain</a>
	<a href={ "notok" }>Literal relative</a>
	/* ErrHardcodedHref: empty href */
	<a href="">Empty</a>
	/* ErrHardcodedHref: query-only */
	<a href="?tab=settings">Query</a>
	/* ErrHardcodedHref: relative path */
	<a href="relative">Relative</a>
	/* ErrHardcodedHref: javascript */
	<a href="javascript:void(0)">JS</a>
	<div>
		<div>
			/* ErrHardcodedHref: nested in divs */
			<a href="/nested">Nested</a>
		</div>
	</div>
	/* ErrHrefUnverifiable: function call not from href package */
	<a href={ loginHref() }>Login func</a>
	/* ErrHrefUnverifiable: function call not from href package */
	<a href={ someOtherFunc() }>Other func</a>
	/* ErrHrefUnverifiable: function call not from href package */
	<a href={ buildURL(id) }>Build URL</a>
	/* ErrHrefUnverifiable: fmt.Sprintf can't be statically verified */
	<a href={ fmt.Sprintf("mailto:%s", "test@example.com") }>Email us</a>
	/* ErrExternalWithInternal: href.External with internal URL */
	<a href={ href.External("/login") }>Bad external</a>
	/* ErrExternalWithInternal: href.External with internal constant */
	<a href={ href.External(InternalConst) }>Bad external const</a>
	/* non-directive mention of datapages:nolint must NOT suppress */
	<a href="/should-error">False nolint</a>
	/* ErrHardcodedHref: imported constant with internal URL */
	<a href={ urls.LoginURL }>Imported internal</a>
	/* ErrExternalWithInternal: href.External with imported internal constant */
	<a href={ href.External(urls.InternalURL) }>Bad external imported</a>
}
