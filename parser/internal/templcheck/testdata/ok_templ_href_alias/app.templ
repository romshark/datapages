package app

import myhref "datapagestest/fixture/ok_templ_href_alias/datapagesgen/href"

templ page() {
	<a href={ myhref.PageIndex() }>Index</a>
	<a href={ myhref.PageProfile("alice") }>Profile</a>
	<a href={ myhref.External("https://example.com") }>External</a>
	<a href={ myhref.Asset("style.css") }>Asset</a>
}
