package app

templ page() {
	/* ErrTemplHardcodedHref */
	<a href="/login">Login</a>
	/* ErrTemplHardcodedHref */
	<a href="/profile">Profile</a>
	/* ErrTemplHardcodedAction */
	<form action="/submit">
		<button type="submit">Submit</button>
	</form>
	<a href="/static/style.css">OK static</a>
	<a href="https://example.com">OK external</a>
	<a href={ loginHref() }>OK expression</a>
	//datapages:nolint
	<a href="/suppressed">Suppressed</a>
}
